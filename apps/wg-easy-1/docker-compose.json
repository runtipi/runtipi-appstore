{
  "services": [
    {
      "name": "wg-easy",
      "image": "ghcr.io/wg-easy/wg-easy:15.3.0",
      "isMain": true,
      "internalPort": 51821,
      "addPorts": [
        {
          "hostPort": 51820,
          "containerPort": 51820,
          "udp": true
        }
      ],
      "environment": [
        {
          "key": "INSECURE",
          "value": "${WIREGUARD_INSECURE}"
        },
        {
          "key": "DISABLE_IPV6",
          "value": "${WIREGUARD_DISABLE_IPV6}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/etc/wireguard"
        }
      ],
      "sysctls": {
        "net.ipv4.conf.all.src_valid_mark": 1,
        "net.ipv4.ip_forward": 1
      },
      "capAdd": ["NET_ADMIN", "SYS_MODULE"]
    }
  ],
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json"
}
